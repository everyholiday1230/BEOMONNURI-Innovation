# ──────────────────────────────────────────────────────────
# Docker Compose 환경용 (.env.docker)
# 프로덕션 배포 시 반드시 JWT_SECRET / ADMIN_KEY 교체
# ──────────────────────────────────────────────────────────
ENV=prod
DATABASE_URL=postgresql+asyncpg://chart:chart@postgres:5432/chart_os
REDIS_URL=redis://redis:6379/0
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_OF_AT_LEAST_32_CHARS
JWT_EXPIRE_MINUTES=43200
JWT_REFRESH_EXPIRE_DAYS=30
ADMIN_KEY=
OLLAMA_URL=http://ollama:11434/api/generate
CORS_ORIGINS=http://localhost:3000

# BitMart / Bitget 키는 실제 값으로 교체 (선택)
BITMART_API_KEY=
BITMART_API_SECRET=
BITMART_API_MEMO=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
