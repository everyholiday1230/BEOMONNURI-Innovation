# ═══ 차트OS 환경 변수 ═══
# 이 파일을 .env로 복사 후 값을 채워주세요.
# cp .env.example .env

# ─── 데이터베이스 ───
DATABASE_URL=postgresql+asyncpg://chart:chart@localhost:5432/chart_os
# 커넥션 풀 크기. Render basic-256mb DB는 최대 100 connection 이므로
# 단일 프로세스가 과도하게 열지 않도록 보수적으로 설정(기본 10+10=최대20).
# 상위 DB 플랜(basic-1gb 등)으로 올리면 값을 키울 수 있음.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
PGPASSWORD=chart

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── JWT 인증 ───
# SECRET_KEY: 앱 전역 시크릿. JWT_SECRET 미설정 시 이 값을 폴백으로 사용.
SECRET_KEY=your-app-secret-minimum-32-chars-here
JWT_SECRET=your-secret-key-minimum-32-chars-here
JWT_EXPIRE_MINUTES=10080
# JWT_REFRESH_EXPIRE_DAYS: 리프레시 토큰 만료(일). 미설정 시 기본 30.
JWT_REFRESH_EXPIRE_DAYS=30

# ─── 관리자 ───
ADMIN_KEY=your-admin-key
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── CORS ───
CORS_ORIGINS=http://localhost:8000,https://yourdomain.com

# ─── 공개 URL ───
PUBLIC_BASE_URL=http://localhost:8000

# ─── AI 모델 (선택) ───
AFIAN_AI_PATH=models/ai_model

# ─── 거래소 API (봇 전용, 선택) ───
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ─── 결제 웹훅 (PG 연동) ───
# PG webhook 요청 body(raw) 기반 HMAC-SHA256 검증 키
PAYMENT_WEBHOOK_SECRET=replace-with-random-long-secret

# ─── 환경 구분 ───
# ENV=production  # production / development

# ── 나만의 AI 신호 (대화형 신호 생성) ──
# 기본 동작: 규칙 기반 파서(무료·즉시·외부 의존 없음)로 자연어를 신호로 변환.
#   예) "RSI가 30 아래로 내려가면 매수", "20일선이 50일선 위로 뚫으면 매수",
#       "가격이 70000 위로 가면 매도"
# 아래 값은 LLM 폴백을 켰을 때(LLM_SIGNAL_USE_OLLAMA=1)만 사용된다.

# LLM 폴백 사용 여부. 기본 0(규칙 파서만, 완전 무료).
# 1로 켜면 규칙 파서가 실패한 문장만 Ollama로 재시도한다(외부 LLM 필요).
LLM_SIGNAL_USE_OLLAMA=0

# Ollama 서버 경로 및 모델 (llm_commentary / llm_signal 공용, 폴백용)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
# 나만의 AI 신호 전용 모델(미설정 시 OLLAMA_MODEL 사용). 표준 Ollama 모델 권장.
LLM_SIGNAL_MODEL=llama3
# 토큰당 포인트 환율 (기본 1토큰=1포인트). 값이 클수록 저렴. 예: 10 → 10토큰당 1P
LLM_TOKEN_PER_POINT=1
# LLM 신호 생성 요청 타임아웃(초)
LLM_SIGNAL_TIMEOUT=40
# 동시 LLM 추론 최대 수(512MB 서버 보호). 초과 요청은 잠시 대기 후 busy.
LLM_SIGNAL_MAX_CONCURRENCY=2
# 세마포어 대기 최대 시간(초). 초과 시 429 busy 로 빠른 실패.
LLM_SIGNAL_ACQUIRE_TIMEOUT=8
