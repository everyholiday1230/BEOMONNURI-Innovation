# ─────────────────────────────────────────────────────────────
# 마음맞춤 환경변수
# ─────────────────────────────────────────────────────────────
PORT=3000

# AI 모델: HyperCLOVA X SEED 0.5B (OpenAI 호환 서버로 셀프호스팅 권장)
# 예) vLLM:   python -m vllm.entrypoints.openai.api_server --model naver-hyperclovax/HyperCLOVAX-SEED-Text-Instruct-0.5B
#     Ollama: ollama run hf.co/naver-hyperclovax/HyperCLOVAX-SEED-Text-Instruct-0.5B
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=not-needed-for-local
AI_MODEL=HyperCLOVAX-SEED-Text-Instruct-0.5B

# AI 서버가 없어도 결정론적 규칙 엔진으로 동작합니다(폴백).
# true 로 두면 외부 AI 호출을 아예 끄고 규칙 엔진만 사용합니다.
AI_DISABLED=false
